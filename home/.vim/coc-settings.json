{
  "diagnostic.enable": true,
  "yaml.format.enable": true,
  "yaml.format.singleQuote": true,
  "yaml.validate": true,
  "yaml.hover": true,
  "yaml.completion": true,
  "yaml.trace.server": "verbose",
  "languageserver": {
      "golang": {
        "command": "gopls",
        "rootPatterns": ["go.mod"],
        "filetypes": ["go"]
      },
      "terraform": {
        "command": "terraform-lsp",
        "filetypes": ["terraform", "tf"],
        "initializationOptions": {},
        "settings": {}
      }
  },
  "diagnostic.displayByAle": true,

  "yaml.schemas": {
      "Kubernetes": ["*.yml"],
      "http://json.schemastore.org/ansible-role-2.9": ["tasks/*.yaml", "tasks/*.yml"],
      "http://json.schemastore.org/ansible-inventory": ["inventory*"],
      "helm": {
          "$schema": "http://json-schema.org/schema#",
          "type": "object",
          "required": [
            "image"
          ],
          "properties": {
            "image": {
              "type": "object",
              "required": [
                "repository",
                "pullPolicy"
              ],
              "properties": {
                "repository": {
                  "type": "string",
                  "pattern": "^[a-z0-9-_]+$"
                },
                "pullPolicy": {
                  "type": "string",
                  "pattern": "^(Always|Never|IfNotPresent)$"
                }
              }
            }
          }
        }
    }
}
